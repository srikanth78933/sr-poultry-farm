# Copy this file to .env and fill in your values
# DO NOT commit .env to git

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=sr_poultry
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
POSTGRES_DB=sr_poultry_db

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_64_RANDOM_HEX_CHARACTERS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# ── First Admin Account ───────────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@natukodifarms.com
FIRST_ADMIN_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
FIRST_ADMIN_NAME=Farm Admin

# ── CORS — add your real domain here ─────────────────────────────────────────
# Example: BACKEND_CORS_ORIGINS=https://natukodifarms.com,https://www.natukodifarms.com
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/app/storage/uploads
PUBLIC_MEDIA_URL=/media

# ── Public site URL — used to build the WhatsApp one-tap review link ─────────
APP_BASE_URL=https://natukodifarms.com

# ── WhatsApp admin alerts (CallMeBot — free, no Meta Business account needed) ─
# 1. Save +34 644 59 71 45 in your phone contacts.
# 2. WhatsApp it: "I allow callmebot to send me messages"
# 3. You'll receive your API key back — paste it below.
# https://www.callmebot.com/blog/free-api-whatsapp-messages/
ADMIN_WHATSAPP_NUMBER=91XXXXXXXXXX
CALLMEBOT_API_KEY=
