# ----- Backend environment -----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=sr_poultry
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=sr_poultry_db

# Security (generate: openssl rand -hex 32)
SECRET_KEY=change_this_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALGORITHM=HS256

# Default admin (created on first boot)
FIRST_ADMIN_EMAIL=admin@srpoultryfarm.com
FIRST_ADMIN_PASSWORD=Admin@12345
FIRST_ADMIN_NAME=Farm Admin

# CORS - comma separated origins
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost

# Storage: "local" or "s3"
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/app/storage/uploads
PUBLIC_MEDIA_URL=/media

# AWS S3 (future migration)
AWS_S3_BUCKET=
AWS_S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_PUBLIC_BASE_URL=
